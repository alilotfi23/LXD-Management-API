# =============================================================================
# LXD Management API — environment configuration (both connection modes)
# =============================================================================
# Copy this file to `.env` and adjust the values for your environment.
# Everything below is documented in the README under "Configuration".

# ---- Application ----
APP_NAME=LXD Management API
APP_ENV=development                       # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO                            # DEBUG | INFO | WARNING | ERROR

# CORS — comma-separated list of allowed origins (use "*" to allow all)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ============================================================================
# LXD CONNECTION
# ============================================================================
# Two modes are supported and selected by LXD_CONNECTION_MODE.
#
#   local  -> connect over the Unix socket exposed by the LXD daemon.
#             No TLS credentials needed. The API server and LXD must be on the
#             same host (or the socket must be bind-mounted into the container).
#
#   remote -> connect over HTTPS using mutual TLS (client cert + key).
#             This is how LXD's own remote clients (lxc remote add) authenticate.
# ============================================================================

LXD_CONNECTION_MODE=local                 # local | remote

# --- local mode ---
# Native install (apt/deb):  /var/lib/lxd/unix.socket
# Snap install:              /var/snap/lxd/common/lxd/unix.socket
LXD_SOCKET_PATH=/var/snap/lxd/common/lxd/unix.socket

# --- remote mode (used only when LXD_CONNECTION_MODE=remote) ---
LXD_REMOTE_URL=https://lxd-host:8443
LXD_CLIENT_CERT_PATH=/run/secrets/lxd/client.crt
LXD_CLIENT_KEY_PATH=/run/secrets/lxd/client.key
# Server CA to verify the LXD host certificate (set to "" to disable verification)
LXD_TRUSTED_CA_PATH=/run/secrets/lxd/server-ca.crt
# Per-request timeout (seconds) for synchronous LXD REST calls
LXD_TIMEOUT=30

# ============================================================================
# Database (SQLite) — used only for storing users / JWT auth subjects.
# LXD itself has its own state and is never touched by this database.
# ============================================================================
DATABASE_URL=sqlite+aiosqlite:///./data/lxd_api.db

# ============================================================================
# JWT (auth for clients of THIS API — separate from LXD's TLS auth)
# ============================================================================
# Generate a strong secret, e.g.:  openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-secret-value
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Default admin account seeded on first startup (set both to enable seeding;
# leave blank to skip seeding and create users via /auth/register instead).
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=changeme123
